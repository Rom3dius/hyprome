#!/bin/bash
set -e

ZSH="${ZSH:-$HOME/.oh-my-zsh}"
DOTS_REPO="https://github.com/Rom3dius/hyprome-dev-dots"

install_omz() {
  echo "[OMZ] Installing for user $USER..."
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
}

update_omz() {
  echo "[OMZ] Updating for user $USER..."
  "$ZSH/tools/upgrade.sh" || true
}

install_dots() {
  echo "[DOTS] Installing for user $USER..."
  yadm clone -f $DOTS_REPO
  yadm checkout "/home/$USER"
}

# Check for oh-my-zsh install
if [ -d "$ZSH" ]; then
  update_omz
else
  install_omz
  install_dots
fi
