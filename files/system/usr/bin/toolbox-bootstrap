#!/usr/bin/env bash
#
# toolbox-bootstrap ─ run all toolbox‑setup scripts and report failures
#
# Copy this file somewhere on $PATH, mark it executable (chmod +x),
# and call it from a login hook, systemd‑user unit, or manually.

set -u          # fail on undefined variables
set -o pipefail # catch errors in pipes
shopt -s nullglob

TOOLBOX_DIR="${TOOLBOX_DIR:-$HOME/.toolboxes}"
SCRIPTS=("$TOOLBOX_DIR"/*.sh)

if [[ ${#SCRIPTS[@]} -eq 0 ]]; then
  echo "⚠  No scripts found in $TOOLBOX_DIR"
  exit 0
fi

echo "▶  Running toolbox setup scripts in $TOOLBOX_DIR …"
echo

failed=()

for script in "${SCRIPTS[@]}"; do
  [[ -x "$script" ]] || chmod +x -- "$script"
  printf "➜  %-40s … " "$(basename "$script")"
  if "$script" ; then
    echo "done ✓"
  else
    echo "FAILED ✗"
    failed+=("$(basename "$script")")
  fi
done

echo
if (( ${#failed[@]} )); then
  echo "❌  The following script(s) exited non‑zero:"
  for s in "${failed[@]}";  do echo "   • $s"; done
  exit 1
else
  echo "✅  All toolbox scripts completed successfully."
fi
